{
  "name": "KnowledgeItem",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string",
      "description": "Company this knowledge item belongs to"
    },
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "best_practice",
        "negotiation_strategy",
        "documentation",
        "scope_guidance",
        "carrier_insight",
        "pricing",
        "dispute_resolution",
        "technical_procedure"
      ]
    },
    "content": {
      "type": "string"
    },
    "related_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_by": {
      "type": "string",
      "description": "User email who created this knowledge item"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "loss_types": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "success_count": {
      "type": "integer",
      "default": 0
    },
    "is_pinned": {
      "type": "boolean",
      "default": false
    },
    "is_deleted": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "company_id",
    "title",
    "category",
    "content",
    "created_by"
  ],
  "rls": {
    "read": {
      "data.company_id": "{{user.company_id}}"
    },
    "create": {
      "data.company_id": "{{user.company_id}}"
    },
    "update": {
      "data.company_id": "{{user.company_id}}",
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "data.created_by": "{{user.email}}"
        }
      ]
    },
    "delete": {
      "data.company_id": "{{user.company_id}}",
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "data.created_by": "{{user.email}}"
        }
      ]
    }
  }
}